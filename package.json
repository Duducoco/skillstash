{
  "name": "skillstash",
  "version": "0.9.0",
  "description": "Git-based skill stash - manage, sync & share agent skills across devices",
  "type": "module",
  "bin": {
    "skillstash": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build && npm test",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "skillstash",
    "skill",
    "stash",
    "sync",
    "agent",
    "workbuddy",
    "codex",
    "claude code",
    "gemini",
    "git",
    "cli"
  ],
  "author": "Duducoco",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.2",
    "chalk": "^5.3.0",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.12.0"
  }
}
